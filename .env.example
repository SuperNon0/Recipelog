# ========================================
# RecipeLog — Configuration
# ========================================

# Base de données PostgreSQL
DATABASE_URL=postgresql://recipelog:motdepasse@localhost:5432/recipelog

# Serveur
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# URL publique du frontend
PUBLIC_URL=https://recipe.super-nono.cc

# Uploads (chemin absolu vers le dossier de stockage des images)
UPLOAD_DIR=/var/lib/recipelog/uploads
MAX_FILE_SIZE_MB=10

# PDF (chemin absolu vers le dossier de génération PDF)
PDF_TEMP_DIR=/tmp/recipelog-pdf

# Logs
LOG_DIR=/var/log/recipelog
LOG_LEVEL=info

# Cloudflare Zero Trust (header transmis par CF)
CF_AUTH_EMAIL_HEADER=Cf-Access-Authenticated-User-Email

# Partage public — Longueur du token UUID
SHARE_TOKEN_LENGTH=12
